  },
  "dependencies": {
    "@agentport/core": "workspace:*",
    "@agentport/db": "workspace:*",
    "fastify": "5.8.5",
    "playwright": "1.61.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
