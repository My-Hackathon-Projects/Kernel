{
  "name": "@agentport/runner",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "PLAYWRIGHT_BROWSERS_PATH=../../.cache/ms-playwright tsx watch src/index.ts",
