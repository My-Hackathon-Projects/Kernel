# Local development defaults.
# Copy this file to .env and fill in real values locally. Do not commit .env.

DATABASE_URL="file:./dev.db"

DASHBOARD_PORT=3000
DASHBOARD_BASE_URL="http://localhost:3000"

RUNNER_HOST="127.0.0.1"
RUNNER_PORT=4000
RUNNER_BASE_URL="http://127.0.0.1:4000"

MOCK_PORTAL_PORT=3001
MOCK_PORTAL_BASE_URL="http://localhost:3001"

# Reserved for the M7 semantic fallback. Leave unset until that milestone.
ANTHROPIC_API_KEY=""
